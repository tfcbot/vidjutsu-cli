{
  "name": "vidjutsu",
  "version": "0.5.0",
  "bin": {
    "vidjutsu": "./dist/index.mjs"
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.mjs --target node",
    "build:binary": "bun run build:binary:darwin-arm64 && bun run build:binary:darwin-x64 && bun run build:binary:linux-x64 && bun run build:binary:linux-arm64",
    "build:binary:darwin-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile dist/vidjutsu-darwin-arm64",
    "build:binary:darwin-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile dist/vidjutsu-darwin-x64",
    "build:binary:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile dist/vidjutsu-linux-x64",
    "build:binary:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile dist/vidjutsu-linux-arm64",
    "dev": "bun run src/index.ts",
    "sync:spec": "curl -sL https://raw.githubusercontent.com/tfcbot/vidjutsu-openapi/main/openapi/spec.json -o spec/openapi.json"
  },
  "dependencies": {
    "citty": "^0.1"
  }
}
